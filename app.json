{
  "expo": {
    "name": "testapp",
    "slug": "testapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*",
      "assets/models/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.testapp"
    },
    "android": {
      "package": "com.example.testapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client"
    ]
  }
}
