{
  "openapi": "3.1.0",
  "info": {
    "title": "Phone API 명세서",
    "description": "핸드폰 중복 방지 API 문서입니다.",
    "version": "v0.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "equipment",
      "description": "장비 관련 API"
    },
    {
      "name": "Health",
      "description": "헬스 체크 API Test"
    },
    {
      "name": "inventory",
      "description": "인벤토리 관련 API (조회, 수령)"
    }
  ],
  "paths": {
    "/api/inventory/grant": {
      "post": {
        "tags": [
          "inventory"
        ],
        "operationId": "grantItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrantItemRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/equipment/equip": {
      "post": {
        "tags": [
          "equipment"
        ],
        "summary": "장비 장착",
        "description": "장비 장착 요청 처리",
        "operationId": "equip",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EquipRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CharacterEquipmentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "서버 상태 확인",
        "description": "서버 상태를 반환합니다.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/inventory/{userId}": {
      "get": {
        "tags": [
          "inventory"
        ],
        "operationId": "getInventory",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserItemResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/equipment/{userId}": {
      "get": {
        "tags": [
          "equipment"
        ],
        "summary": "착용 장비 확인",
        "description": "현재 장비 착용 상태를 반환합니다.",
        "operationId": "getEquipment",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CharacterEquipmentResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/equipment/{userId}/{slotType}": {
      "delete": {
        "tags": [
          "equipment"
        ],
        "summary": "장비 해제",
        "description": "장비 해제 요청 처리",
        "operationId": "unequip",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "slotType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "HAT",
                "HEAD",
                "BODY",
                "SHOES",
                "ACC"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GrantItemRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "itemId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "EquipRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "itemId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CharacterEquipmentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "slotType": {
            "type": "string"
          },
          "item": {
            "$ref": "#/components/schemas/ItemResponse"
          }
        }
      },
      "ItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "assetAddress": {
            "type": "string"
          },
          "thumbnailUrl": {
            "type": "string"
          },
          "slotType": {
            "type": "string"
          },
          "rarity": {
            "type": "string"
          }
        }
      },
      "UserItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "item": {
            "$ref": "#/components/schemas/ItemResponse"
          },
          "acquiredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}